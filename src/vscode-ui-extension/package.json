{
  "name": "devcontainer-dev-certs-host",
  "displayName": "Dev Container Dev Certificates (Host)",
  "description": "Generates and trusts ASP.NET and Aspire compatible HTTPS development certificates on the host machine for use in Dev Containers and remote environments.",
  "icon": "images/dn_ui_extension_icon_256.png",
  "version": "0.1.3-pre",
  "publisher": "dnegstad",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dnegstad/devcontainer-dev-certs"
  },
  "api": "none",
  "engines": {
    "vscode": "^1.100.0"
  },
  "extensionKind": [
    "ui"
  ],
  "keywords": [
    "dotnet",
    "aspnet",
    "aspire",
    "devcontainer",
    "https"
  ],
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:devcontainer-dev-certs.getCertMaterial"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "devcontainer-dev-certs.trustInBrowsers",
        "title": "Dev Certs: Trust Certificate in Browsers"
      }
    ],
    "configuration": {
      "title": "Dev Certificates (Host)",
      "properties": {
        "devcontainer-dev-certs.autoProvision": {
          "type": "boolean",
          "default": true,
          "description": "Allow certificate provisioning when the workspace extension requests one. On first use, a consent prompt explains what will happen before any certificates are generated. Set to false to disable provisioning entirely."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "build:prod": "node esbuild.mjs --production",
    "watch": "node esbuild.mjs --watch",
    "test": "vitest run",
    "lint": "eslint src --ext ts",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/node-forge": "^1.3.14",
    "@types/vscode": "^1.100.0",
    "@vscode/vsce": "^3.8.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.9.0",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@devcontainer-dev-certs/shared": "*",
    "node-forge": "^1.4.0"
  }
}
