{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build-extensions",
            "dependsOn": [
                "build-ui-extension",
                "build-workspace-extension",
                "stage-test-vsix"
            ],
            "dependsOrder": "sequence",
            "problemMatcher": []
        },
        {
            "label": "build-ui-extension",
            "type": "npm",
            "script": "build",
            "path": "src/vscode-ui-extension",
            "problemMatcher": ["$tsc"]
        },
        {
            "label": "build-workspace-extension",
            "type": "npm",
            "script": "build",
            "path": "src/vscode-workspace-extension",
            "problemMatcher": ["$tsc"]
        },
        {
            "label": "hydrate-test-project",
            "type": "npm",
            "script": "hydrate:sample-project",
            "path": "",
            "detail": "Assembles a runnable test project from the template + feature source into .out/test-project/",
            "problemMatcher": []
        },
        {
            "label": "stage-test-vsix",
            "type": "shell",
            "command": "npx",
            "args": [
                "vsce",
                "package",
                "--out",
                "${workspaceFolder}/.out/test-project/.devcontainer/dotnet-dev-certs-remote.vsix"
            ],
            "options": {
                "cwd": "${workspaceFolder}/src/vscode-workspace-extension"
            },
            "dependsOn": ["hydrate-test-project"],
            "detail": "Packages workspace extension VSIX into the hydrated test project for local devcontainer testing",
            "problemMatcher": []
        },
        {
            "label": "watch-extensions",
            "dependsOn": [
                "watch-ui-extension",
                "watch-workspace-extension"
            ],
            "dependsOrder": "parallel",
            "problemMatcher": []
        },
        {
            "label": "watch-ui-extension",
            "type": "npm",
            "script": "watch",
            "path": "src/vscode-ui-extension",
            "isBackground": true,
            "problemMatcher": ["$tsc"]
        },
        {
            "label": "watch-workspace-extension",
            "type": "npm",
            "script": "watch",
            "path": "src/vscode-workspace-extension",
            "isBackground": true,
            "problemMatcher": ["$tsc"]
        }
    ],
    "inputs": []
}
